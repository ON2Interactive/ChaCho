{
  "name": "chacho",
  "private": true,
  "version": "0.1.0",
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:dashboard": "npm run dev -w dashboard",
    "dev:widget": "npm run dev -w widget",
    "db:generate": "npm run db:generate -w @chacho/db",
    "db:migrate": "npm run db:migrate -w @chacho/db",
    "db:seed": "npm run db:seed -w @chacho/db"
  }
}
