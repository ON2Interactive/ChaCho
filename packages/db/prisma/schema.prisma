generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum MembershipRole {
  OWNER
  AGENT
}

enum ConversationStatus {
  OPEN
  CLOSED
}

enum MessageSenderType {
  VISITOR
  AGENT
  SYSTEM
}

model Tenant {
  id          String         @id @default(uuid()) @db.Uuid
  name        String
  slug        String         @unique
  status      TenantStatus   @default(TRIAL)
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  memberships Membership[]
  widgets     Widget[]
  visitors    Visitor[]
  conversations Conversation[]
  messages    Message[]

  @@map("tenants")
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique
  name         String?
  passwordHash String?      @map("password_hash")
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)
  memberships  Membership[]
  messages     Message[]

  @@map("users")
}

model Membership {
  id        String         @id @default(uuid()) @db.Uuid
  tenantId  String         @map("tenant_id") @db.Uuid
  userId    String         @map("user_id") @db.Uuid
  role      MembershipRole
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@map("memberships")
}

model Widget {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  name            String
  publicKey       String         @unique @map("public_key")
  domainAllowlist Json           @default("[]") @map("domain_allowlist")
  themeJson       Json           @default("{}") @map("theme_json")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  visitors        Visitor[]
  conversations   Conversation[]

  @@map("widgets")
}

model Visitor {
  id           String         @id @default(uuid()) @db.Uuid
  tenantId     String         @map("tenant_id") @db.Uuid
  widgetId     String         @map("widget_id") @db.Uuid
  browserToken String         @map("browser_token")
  name         String?
  email        String?
  firstSeenAt  DateTime       @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt   DateTime       @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  widget       Widget         @relation(fields: [widgetId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@index([tenantId, widgetId])
  @@index([tenantId, browserToken])
  @@map("visitors")
}

model Conversation {
  id            String             @id @default(uuid()) @db.Uuid
  tenantId      String             @map("tenant_id") @db.Uuid
  widgetId      String             @map("widget_id") @db.Uuid
  visitorId     String             @map("visitor_id") @db.Uuid
  status        ConversationStatus @default(OPEN)
  sourceUrl     String             @map("source_url")
  sourceTitle   String?            @map("source_title")
  startedAt     DateTime           @default(now()) @map("started_at") @db.Timestamptz(6)
  lastMessageAt DateTime           @default(now()) @map("last_message_at") @db.Timestamptz(6)
  closedAt      DateTime?          @map("closed_at") @db.Timestamptz(6)
  tenant        Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  widget        Widget             @relation(fields: [widgetId], references: [id], onDelete: Cascade)
  visitor       Visitor            @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@index([tenantId, status, lastMessageAt(sort: Desc)])
  @@index([tenantId, visitorId])
  @@map("conversations")
}

model Message {
  id             String            @id @default(uuid()) @db.Uuid
  tenantId       String            @map("tenant_id") @db.Uuid
  conversationId String            @map("conversation_id") @db.Uuid
  senderType     MessageSenderType @map("sender_type")
  senderUserId   String?           @map("sender_user_id") @db.Uuid
  body           String
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversation   Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser     User?             @relation(fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, conversationId, createdAt])
  @@map("messages")
}
